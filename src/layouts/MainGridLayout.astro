---
import BackToTop from "@components/control/BackToTop.astro";
import Footer from "@components/Footer.astro";
import Navbar from "@components/Navbar.astro";
import type { MarkdownHeading } from "astro";
import { Icon } from "astro-icon/components";
import ImageWrapper from "../components/misc/ImageWrapper.astro";
import Announcement from "../components/widget/Announcement.astro";
import TOC from "../components/widget/TOC.astro";
import { siteConfig } from "../config";
import {
	BANNER_HEIGHT,
	BANNER_HEIGHT_EXTEND,
	MAIN_PANEL_OVERLAPS_BANNER_HEIGHT,
} from "../constants/constants";
import Layout from "./Layout.astro";

interface Props {
	title?: string;
	banner?: string;
	description?: string;
	lang?: string;
	setOGTypeArticle?: boolean;
	headings?: MarkdownHeading[];
	tocLeft?: boolean;
}

const {
	title,
	banner,
	description,
	lang,
	setOGTypeArticle,
	headings = [],
	tocLeft = false,
} = Astro.props;
const hasBannerCredit =
	siteConfig.banner.enable && siteConfig.banner.credit.enable;
const hasBannerLink = !!siteConfig.banner.credit.url;

const mainPanelTop = siteConfig.banner.enable
	? `calc(${BANNER_HEIGHT}vh - ${MAIN_PANEL_OVERLAPS_BANNER_HEIGHT}rem)`
	: "5.5rem";
---

<Layout title={title} banner={banner} description={description} lang={lang} setOGTypeArticle={setOGTypeArticle}>

<!-- Navbar -->
<slot slot="head" name="head"></slot>
<div id="top-row" class="z-50 pointer-events-none fixed top-0 left-0 right-0 max-w-[var(--page-width)] px-0 md:px-4 mx-auto">
    <div id="navbar-wrapper" class="pointer-events-auto sticky top-0 transition-colors duration-300">
        <Navbar></Navbar>
    </div>
</div>

<!-- Banner -->
{siteConfig.banner.enable && <div id="banner-wrapper" class={`absolute z-10 w-full overflow-hidden transition-opacity duration-500`} style={`top: -${BANNER_HEIGHT_EXTEND}vh`}>
    <ImageWrapper id="banner" alt="Banner image of the blog" class:list={["object-cover h-full opacity-0 scale-105 transition-opacity duration-500"]}
                  src={siteConfig.banner.src} position={siteConfig.banner.position}
    >
    </ImageWrapper>
</div>}

<!-- Main content -->
<div class="absolute w-full z-30 pointer-events-none" style={`top: ${mainPanelTop}`}>
    <!-- The pointer-events-none here prevent blocking the click event of the TOC -->
    <div class="relative max-w-[var(--page-width)] mx-auto pointer-events-auto">
        {siteConfig.announcement.enable && <div class="px-4 md:px-4">
            <Announcement class="onload-animation" />
        </div>}
        <div id="main-grid" class="w-full left-0 right-0 grid grid-cols-1 grid-rows-[auto_1fr_auto]
    mx-auto gap-4 px-0 md:px-4" style={`min-height: calc(100vh - ${mainPanelTop})`}
        >
            <!-- Banner image credit -->
            {hasBannerCredit && <a href={siteConfig.banner.credit.url} id="banner-credit" target="_blank" rel="noopener" aria-label="Visit image source"
                                   class:list={["group onload-animation absolute flex justify-center items-center rounded-full " +
                                   "px-3 right-4 -top-[3.25rem] bg-black/60 hover:bg-black/70 h-9 transition-colors duration-300", {"hover:pr-9 active:bg-black/80": hasBannerLink}]}
            >
                <Icon class="text-white/75 text-[1.25rem] mr-1" name="material-symbols:copyright-outline-rounded" ></Icon>
                <div class="text-white/75 text-xs">{siteConfig.banner.credit.text}</div>
                <Icon class:list={["absolute text-[oklch(0.75_0.14_var(--hue))] right-4 text-[0.75rem] opacity-0 transition-opacity duration-300",
                    {"group-hover:opacity-100": hasBannerLink}]}
                      name="fa6-solid:arrow-up-right-from-square">
                </Icon>
            </a>}

            <main id="swup-container" class="transition-swup-fade col-span-1 overflow-hidden">
                <div id="content-wrapper" class="onload-animation w-full h-full flex flex-col">
                    <!-- the overflow-hidden here prevent long text break the layout-->
                    <!-- make id different from windows.swup global property -->
                    <div class="flex-1">
                        <slot></slot>
                    </div>
                    <div class="footer col-span-1 onload-animation hidden lg:block">
                        <Footer></Footer>
                    </div>
                </div>
            </main>

            <div class="footer col-span-1 onload-animation block lg:hidden">
                <Footer></Footer>
            </div>
        </div>

        <BackToTop></BackToTop>
    </div>
</div>

<!-- The things that should be under the banner, only the TOC for now -->
<div class="absolute w-full z-0 hidden xl:block">
    <div class="relative max-w-[var(--page-width)] mx-auto">
        <!-- TOC component -->
        {siteConfig.toc.enable && <div id="toc-wrapper" class:list={["hidden lg:block absolute top-0 w-[var(--toc-width)] items-center",
            tocLeft ? "-left-[var(--toc-width)]" : "-right-[var(--toc-width)]",
            {"toc-hide": siteConfig.banner.enable}]}
        >
            <div id="toc" class="w-full h-full transition-swup-fade">
                {headings.length > 0 && (
                    <div class="fixed top-[5.5rem] w-[var(--toc-width)] h-[calc(100vh_-_20rem)] bg-[var(--card-bg)] rounded-[var(--radius-large)] transition-colors duration-300">
                        <div id="toc-inner-wrapper" class="w-full h-full overflow-y-scroll overflow-x-hidden hide-scrollbar">
                            <div class="h-8 w-full"></div>
                            <TOC headings={headings}></TOC>
                            <div class="h-8 w-full"></div>
                        </div>
                    </div>
                )}
            </div>
        </div>}

        <!-- #toc needs to exist for Swup to work normally -->
        {!siteConfig.toc.enable && <div id="toc"></div>}
    </div>
</div>
</Layout>
