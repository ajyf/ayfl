---
import "@fontsource/roboto/400.css";
import "@fontsource/roboto/500.css";
import "@fontsource/roboto/700.css";

import ConfigCarrier from "@components/ConfigCarrier.astro";
import { profileConfig, siteConfig } from "@/config";
import {
	AUTO_MODE,
	BANNER_HEIGHT,
	BANNER_HEIGHT_EXTEND,
	BANNER_HEIGHT_HOME,
	DARK_MODE,
	DEFAULT_THEME,
	LIGHT_MODE,
	PAGE_WIDTH,
} from "../constants/constants";
import { defaultFavicons } from "../constants/icon";
import type { Favicon } from "../types/config";
import { pathsEqual, url } from "../utils/url-utils";
import "katex/dist/katex.css";
import path from "node:path";
import { getImage } from "astro:assets";

interface Props {
	title?: string;
	banner?: string;
	description?: string;
	lang?: string;
	setOGTypeArticle?: boolean;
}

let { title, banner, description, lang, setOGTypeArticle } = Astro.props;

// apply a class to the body element to decide the height of the banner, only used for initial page load
// Swup can update the body for each page visit, but it's after the page transition, causing a delay for banner height change
// so use Swup hooks instead to change the height immediately when a link is clicked
const isHomePage = pathsEqual(Astro.url.pathname, url("/"));

// defines global css variables
// why doing this in Layout instead of GlobalStyles: https://github.com/withastro/astro/issues/6728#issuecomment-1502203757
const configHue = siteConfig.themeColor.hue;
if (!banner || typeof banner !== "string" || banner.trim() === "") {
	banner = siteConfig.banner.src;
}

// TODO don't use post cover as banner for now
banner = siteConfig.banner.src;

const enableBanner = siteConfig.banner.enable;

let pageTitle: string;
if (title) {
	pageTitle = `${title} - ${siteConfig.title}`;
} else {
	pageTitle = `${siteConfig.title} - ${siteConfig.subtitle}`;
}

const favicons: Favicon[] =
	siteConfig.favicon.length > 0 ? siteConfig.favicon : defaultFavicons;

// const siteLang = siteConfig.lang.replace('_', '-')
if (!lang) {
	lang = `${siteConfig.lang}`;
}
const siteLang = lang.replace("_", "-");

const bannerOffsetByPosition = {
	top: `${BANNER_HEIGHT_EXTEND}vh`,
	center: `${BANNER_HEIGHT_EXTEND / 2}vh`,
	bottom: "0",
};
const bannerOffset =
	bannerOffsetByPosition[siteConfig.banner.position || "center"];

const bgSrc = siteConfig.background.src;
const isLocal =
	bgSrc &&
	!(
		bgSrc.startsWith("/") ||
		bgSrc.startsWith("http") ||
		bgSrc.startsWith("https") ||
		bgSrc.startsWith("data:")
	);
const isPublic = bgSrc && bgSrc.startsWith("/");

let resolvedBgUrl = "none";
if (bgSrc) {
	if (isLocal) {
		const files = import.meta.glob<ImageMetadata>("../**", {
			import: "default",
		});
		const normalizedPath = path
			.normalize(path.join("../", bgSrc))
			.replace(/\\/g, "/");
		const file = files[normalizedPath];
		if (file) {
			const img = (await file()) as ImageMetadata;
			const optimized = await getImage({ src: img });
			resolvedBgUrl = `url(${optimized.src})`;
		} else {
			console.error(
				`\n[ERROR] Background image file not found: ${normalizedPath.replace("../", "src/")}`,
			);
			resolvedBgUrl = "none";
		}
	} else if (isPublic) {
		resolvedBgUrl = `url(${url(bgSrc)})`;
	} else {
		resolvedBgUrl = `url(${bgSrc})`;
	}
}
---

<!DOCTYPE html>
<html lang={siteLang} class="bg-[var(--page-bg)] text-[14px] md:text-[16px]"
	  data-overlayscrollbars-initialize
>
	<head>

		<title>{pageTitle}</title>

		<meta charset="UTF-8" />
		<meta name="description" content={description || pageTitle}>
		<meta name="author" content={profileConfig.name}>

		<meta property="og:site_name" content={siteConfig.title}>
		<meta property="og:url" content={Astro.url}>
		<meta property="og:title" content={pageTitle}>
		<meta property="og:description" content={description || pageTitle}>
		{setOGTypeArticle ? (
        <meta property="og:type" content="article" />
        ) : (
        <meta property="og:type" content="website" />
        )}

		<meta name="twitter:card" content="summary_large_image">
		<meta property="twitter:url" content={Astro.url}>
		<meta name="twitter:title" content={pageTitle}>
		<meta name="twitter:description" content={description || pageTitle}>

		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		{favicons.map(favicon => (
			<link rel="icon"
				  href={favicon.src.startsWith('/') ? url(favicon.src) : favicon.src}
				  sizes={favicon.sizes}
				  media={favicon.theme && `(prefers-color-scheme: ${favicon.theme})`}
			/>
		))}

		<!-- Set the theme before the page is rendered to avoid a flash -->
		<script is:inline define:vars={{DEFAULT_THEME, LIGHT_MODE, DARK_MODE, AUTO_MODE, BANNER_HEIGHT_EXTEND, PAGE_WIDTH, configHue, configBgEnable: siteConfig.background.enable ? '1' : '0'}}>
			// Load the theme from local storage
			const theme = localStorage.getItem('theme') || DEFAULT_THEME;
			switch (theme) {
				case LIGHT_MODE:
					document.documentElement.classList.remove('dark');
					break
				case DARK_MODE:
					document.documentElement.classList.add('dark');
					break
				case AUTO_MODE:
					if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
						document.documentElement.classList.add('dark');
					} else {
						document.documentElement.classList.remove('dark');
					}
			}

			// Load the hue from local storage
			const hue = localStorage.getItem('hue') || configHue;
			document.documentElement.style.setProperty('--hue', hue);

            // Load the background blur from local storage
            const bgBlur = localStorage.getItem('bg-blur') || '0';
            document.documentElement.style.setProperty('--bg-blur', `${bgBlur}px`);

            // Load the background enable from local storage
            const bgEnable = localStorage.getItem('bg-enable') || configBgEnable;
            document.documentElement.style.setProperty('--bg-enable', bgEnable);
            document.documentElement.dataset.bgEnable = bgEnable;

			// calculate the --banner-height-extend, which needs to be a multiple of 4 to avoid blurry text
			let offset = Math.floor(window.innerHeight * (BANNER_HEIGHT_EXTEND / 100));
			offset = offset - offset % 4;
			document.documentElement.style.setProperty('--banner-height-extend', `${offset}px`);

			// Background image loading detection
			// Only run on initial page load, not during Swup transitions
			if (!window.swup || !document.body.classList.contains('swup-enabled')) {
				const bgUrl = getComputedStyle(document.documentElement).getPropertyValue('--bg-url').trim();
				
				if (bgUrl && bgUrl !== 'none') {
					const urlMatch = bgUrl.match(/url\(["']?([^"')]+)["']?\)/);
					if (urlMatch) {
						const bgImageUrl = urlMatch[1];
						// Check if background is already loaded (for Swup page transitions)
						if (document.body && document.body.classList.contains('bg-loaded')) {
							// Already loaded, just ensure the styles are applied
							// Use a small delay to allow the new page content to render first
							requestAnimationFrame(() => {
								document.documentElement.style.setProperty('--card-bg', 'var(--card-bg-transparent)');
								document.documentElement.style.setProperty('--float-panel-bg', 'var(--float-panel-bg-transparent)');
							});
						} else {
							const img = new Image();
							img.onload = function() {
								// Background image fully loaded, show background and enable card transparency
								// Use requestAnimationFrame for smoother transition
								requestAnimationFrame(() => {
									if (document.body) {
										document.body.classList.add('bg-loaded');
									}
									document.documentElement.style.setProperty('--card-bg', 'var(--card-bg-transparent)');
									document.documentElement.style.setProperty('--float-panel-bg', 'var(--float-panel-bg-transparent)');
								});
							};
							img.onerror = function() {
								// Keep cards opaque if background image fails to load
								console.warn('Background image failed to load, keeping cards opaque');
							};
							img.src = bgImageUrl;
						}
					}
				}
			}
		</script>
		<style define:vars={{
			configHue,
			'page-width': `${PAGE_WIDTH}rem`,
			'bg-url': resolvedBgUrl,
			'bg-enable': siteConfig.background.enable ? '1' : '0',
			'bg-position': siteConfig.background.position || 'center',
			'bg-size': siteConfig.background.size || 'cover',
			'bg-repeat': siteConfig.background.repeat || 'no-repeat',
			'bg-attachment': siteConfig.background.attachment || 'fixed',
			'bg-opacity': (siteConfig.background.opacity || 0.3).toString(),
		}}>
		</style>

        <style is:global>
            :root {
                --bg-blur: 0px;
            }
			/* Background image configuration */
			body::before {
				content: '' !important;
				position: fixed !important;
				top: 0 !important;
				left: 0 !important;
				width: 100% !important;
				height: 100% !important;
				background-image: var(--bg-url) !important;
				background-position: var(--bg-position) !important;
				background-size: var(--bg-size) !important;
				background-repeat: var(--bg-repeat) !important;
				background-attachment: var(--bg-attachment) !important;
				opacity: 0 !important;
				pointer-events: none !important;
				z-index: -1 !important;
				display: block !important;
				transition: opacity 0.5s ease-in-out, filter 0.5s ease-in-out !important;
				filter: blur(var(--bg-blur)) !important;
			}
			
			body.bg-loaded::before {
				opacity: var(--bg-opacity) !important;
			}

            :root[data-bg-enable="0"] body::before {
                opacity: 0 !important;
            }
        </style>  <!-- defines global css variables. This will be applied to <html> <body> and some other elements idk why -->


		<slot name="head"></slot>

		<link rel="alternate" type="application/rss+xml" title={profileConfig.name} href={`${Astro.site}rss.xml`}/>

	</head>
	<body class=" min-h-screen " class:list={[{"lg:is-home": isHomePage, "enable-banner": enableBanner}]}
		  data-overlayscrollbars-initialize
	>
		<ConfigCarrier></ConfigCarrier>
		<slot />

		<!-- increase the page height during page transition to prevent the scrolling animation from jumping -->
		<div id="page-height-extend" class="hidden h-[300vh]"></div>
		
<style is:global>
	#arkpets-character {
		position: fixed;
		bottom: 0;
		right: 0;
		z-index: 1000;
		pointer-events: none;
	}
</style>

<!-- ArkPets Character Display -->
<script src="/arkpets/arkpets.js" async></script>
<script>
	const BASE_PATH = "/arkpets/models/";
	const CHARACTER_RESOURCES = [
            {
                id: "amgoat",
                name: "艾雅法拉",
                skeleton: "180_amgoat/build_char_180_amgoat.skel", 
                atlas: "180_amgoat/build_char_180_amgoat.atlas",
                texture: "180_amgoat/build_char_180_amgoat.png",
                resourcePath: BASE_PATH,
            },
            {
                id: "amgoat_summer#5",
                name: "艾雅法拉-夏卉 FA018",
                skeleton: "180_amgoat_summer/build_char_180_amgoat_summer.skel", 
                atlas: "180_amgoat_summer/build_char_180_amgoat_summer.atlas",
                texture: "180_amgoat_summer/build_char_180_amgoat_summer.png",
                resourcePath: BASE_PATH,
            },
            {
                id: "amgoat_sanrio",
                name: "艾雅法拉-绵绒小魔女",
                skeleton: "180_amgoat_sanrio/build_char_180_amgoat_sanrio.skel", 
                atlas: "180_amgoat_sanrio/build_char_180_amgoat_sanrio.atlas",
                texture: "180_amgoat_sanrio/build_char_180_amgoat_sanrio.png",
                resourcePath: BASE_PATH,
            },
            {
                id: "agoat2",
                name: "纯烬艾雅法拉",
                skeleton: "1016_agoat2/build_char_1016_agoat2.skel", 
                atlas: "1016_agoat2/build_char_1016_agoat2.atlas",
                texture: "1016_agoat2/build_char_1016_agoat2.png",
                resourcePath: BASE_PATH,
            },
            {
                id: "agoat2_epoque#34",
                name: "纯烬艾雅法拉-远行前的野餐",
                skeleton: "1016_agoat2_epoque/build_char_1016_agoat2_epoque.skel", 
                atlas: "1016_agoat2_epoque/build_char_1016_agoat2_epoque.atlas",
                texture: "1016_agoat2_epoque/build_char_1016_agoat2_epoque.png",
                resourcePath: BASE_PATH,
            }
	];

	async function initArkPets() {
		// Avoid duplicate initialization
		if (document.querySelector('#arkpets-character')) return;

		// Wait for arkpets to be available (max 5s)
		for (let i = 0; i < 50; i++) {
			if (window.arkpets?.Character) break;
			await new Promise(resolve => setTimeout(resolve, 100));
		}

		if (!window.arkpets?.Character) {
			console.error('ArkPets failed to load.');
			return;
		}

		try {
			const container = document.createElement('div');
			container.id = 'arkpets-character';
			document.body.appendChild(container);

			const getRandomElement = (arr) => arr[Math.floor(Math.random() * arr.length)];
			const character = new window.arkpets.Character(
				"arkpets",
				(e) => window.arkpets.showContextMenu(e, character, {
					getCharacterModels: () => CHARACTER_RESOURCES,
				}),
				getRandomElement(CHARACTER_RESOURCES),
			);
			
			container.appendChild(character.canvas);
		} catch (err) {
			console.error("Failed to initialize ArkPets character:", err);
		}
	}

	// Initialize
	initArkPets();

	// Support Swup page transitions
	document.addEventListener('swup:content:replace', initArkPets);
</script>
	</body>
</html>

<style is:global define:vars={{
	bannerOffset,
	'banner-height-home': `${BANNER_HEIGHT_HOME}vh`,
	'banner-height': `${BANNER_HEIGHT}vh`,
}}>
@tailwind components;
@layer components {
	.enable-banner.is-home #banner-wrapper {
		@apply h-[var(--banner-height-home)] translate-y-[var(--banner-height-extend)]
	}
	.enable-banner #banner-wrapper {
		@apply h-[var(--banner-height-home)]
	}

	.enable-banner.is-home #banner {
		@apply h-[var(--banner-height-home)] translate-y-0
	}
	.enable-banner #banner {
		@apply h-[var(--banner-height-home)] translate-y-[var(--bannerOffset)]
	}
	.enable-banner.is-home #main-grid {
		@apply translate-y-[var(--banner-height-extend)];
	}
	.enable-banner #top-row {
		@apply h-[calc(var(--banner-height-home)_-_4.5rem)]
	}
	.enable-banner.is-home #sidebar-sticky {
		@apply top-[calc(1rem_-_var(--banner-height-extend))]
	}
	.navbar-hidden {
		@apply opacity-0 -translate-y-16
	}
}
</style>

<script>
